:root {
  --primary-100: #26a69a;
  --primary-200: #408d86;
  --primary-300: #cdfaf6;
  --accent-100: #80cbc4;
  --accent-200: #43a49b;
  --text-100: #263339;
  --text-200: #728f9e;
  --bg-100: #e0f2f1;
  --bg-200: #d0ebea;
  --bg-300: #ffffff;
  --bg: #eaf7f6;
  --panel: var(--bg-300);
  --brand: var(--primary-100);
  --brand-soft: var(--primary-300);
  --text: var(--text-100);
  --muted: var(--text-200);
  --layout-bg: #f1f3f5;
  --layout-sidebar-bg: #ffffff;
  --layout-sidebar-text: #18262e;
  --layout-sidebar-muted: #8b9aaa;
  --layout-sidebar-hover: #eff8f6;
  --layout-sidebar-active: #dff5ef;
  --layout-header-bg: rgba(241, 243, 245, 0.88);
  --layout-border: rgba(210, 218, 224, 0.72);
  --layout-action-color: #6d7a89;
  --layout-action-hover: rgba(38, 166, 154, 0.08);
  --el-color-primary: var(--primary-100);
  --el-color-primary-light-3: #53b5ab;
  --el-color-primary-light-5: #7cc8c1;
  --el-color-primary-light-7: #a5dcd7;
  --el-color-primary-light-8: #bce9e4;
  --el-color-primary-light-9: #d8f4f1;
  --el-color-primary-dark-2: var(--primary-200);
  --el-text-color-primary: var(--text-100);
  --el-text-color-regular: var(--text-200);
  --el-border-color-light: rgba(64, 141, 134, 0.18);
}

* {
  box-sizing: border-box;
}

html {
  font-size: 1rem;
}

body {
  margin: 0;
  font-family: "Segoe UI", "PingFang SC", sans-serif;
  background: var(--layout-bg);
  color: var(--text);
}

a {
  color: inherit;
  text-decoration: none;
}

.el-button--primary:not(.is-plain):not(.is-link):not(.is-text) {
  color: #ffffff;
  background: #0f766e;
  border-color: #0f766e;
}

.el-button--primary:not(.is-plain):not(.is-link):not(.is-text) > span,
.el-button--primary:not(.is-plain):not(.is-link):not(.is-text) .el-icon {
  color: #ffffff;
}

.el-button--primary:not(.is-plain):not(.is-link):not(.is-text):hover,
.el-button--primary:not(.is-plain):not(.is-link):not(.is-text):focus {
  color: #ffffff;
  background: #0a645d;
  border-color: #0a645d;
}

.el-button--primary:not(.is-plain):not(.is-link):not(.is-text).is-disabled,
.el-button--primary:not(.is-plain):not(.is-link):not(.is-text).is-disabled:hover,
.el-button--primary:not(.is-plain):not(.is-link):not(.is-text).is-disabled:focus {
  color: #eafffc;
  background: #2d7d78;
  border-color: #2d7d78;
  opacity: 1;
}

.el-button--primary:not(.is-plain):not(.is-link):not(.is-text).is-disabled > span,
.el-button--primary:not(.is-plain):not(.is-link):not(.is-text).is-disabled .el-icon {
  color: #d8fff9;
}

.el-button--primary.is-plain:not(.is-link):not(.is-text) {
  color: #0a645d;
  background: #eefaf7;
  border-color: #79c9c0;
}

.el-button--primary.is-plain:not(.is-link):not(.is-text) > span,
.el-button--primary.is-plain:not(.is-link):not(.is-text) .el-icon {
  color: inherit;
}

.el-button--primary.is-plain:not(.is-link):not(.is-text):hover,
.el-button--primary.is-plain:not(.is-link):not(.is-text):focus {
  color: #ffffff;
  background: #0f766e;
  border-color: #0f766e;
}

.el-button--primary.is-plain:not(.is-link):not(.is-text).is-disabled,
.el-button--primary.is-plain:not(.is-link):not(.is-text).is-disabled:hover,
.el-button--primary.is-plain:not(.is-link):not(.is-text).is-disabled:focus {
  color: #526776;
  background: #f3f7f8;
  border-color: #cfdae1;
  opacity: 1;
}

.el-button.is-text.el-button--primary,
.el-button.is-link.el-button--primary {
  color: #0a645d;
}

.el-button.is-text.el-button--primary > span,
.el-button.is-link.el-button--primary > span,
.el-button.is-text.el-button--primary .el-icon,
.el-button.is-link.el-button--primary .el-icon {
  color: inherit;
}

.el-button:not(.el-button--primary):not(.el-button--success):not(.el-button--warning):not(.el-button--danger):not(.el-button--info):not(.is-link):not(.is-text) {
  color: #526776;
}

.el-button:not(.el-button--primary):not(.el-button--success):not(.el-button--warning):not(.el-button--danger):not(.el-button--info):not(.is-link):not(.is-text) > span,
.el-button:not(.el-button--primary):not(.el-button--success):not(.el-button--warning):not(.el-button--danger):not(.el-button--info):not(.is-link):not(.is-text) .el-icon {
  color: inherit;
}

.el-button.is-disabled:not(.el-button--primary):not(.is-link):not(.is-text),
.el-button.is-disabled:not(.el-button--primary):not(.is-link):not(.is-text):hover,
.el-button.is-disabled:not(.el-button--primary):not(.is-link):not(.is-text):focus {
  color: #526776;
  background: #f5f8fa;
  border-color: #cfdae1;
  opacity: 1;
}

.el-button.is-disabled:not(.el-button--primary):not(.is-link):not(.is-text) > span,
.el-button.is-disabled:not(.el-button--primary):not(.is-link):not(.is-text) .el-icon {
  color: #526776;
}

.el-button--danger.is-plain:not(.is-link):not(.is-text) {
  color: #b4232d;
  background: #fff1f2;
  border-color: #ef9fa6;
}

.el-button--danger.is-plain:not(.is-link):not(.is-text):hover,
.el-button--danger.is-plain:not(.is-link):not(.is-text):focus {
  color: #ffffff;
  background: #c93642;
  border-color: #c93642;
}

.el-button--warning.is-plain:not(.is-link):not(.is-text) {
  color: #8a5200;
  background: #fff8eb;
  border-color: #e7bd70;
}

.el-button--warning.is-plain:not(.is-link):not(.is-text):hover,
.el-button--warning.is-plain:not(.is-link):not(.is-text):focus {
  color: #ffffff;
  background: #a96500;
  border-color: #a96500;
}

.page-card {
  background: var(--panel);
  border-radius: 0.75rem;
  padding: 1.125rem 1.25rem;
  border: 0.0625rem solid rgba(64, 141, 134, 0.1);
  box-shadow: 0 0.5rem 1.25rem rgba(38, 166, 154, 0.04);
}

.page-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.hero-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(13.75rem, 1fr));
  gap: 1rem;
}

.manage-shell {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}

.manage-hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  padding: 0 0.125rem 0.125rem;
}

.manage-hero h2 {
  margin: 0;
  font-size: 1.5rem;
  line-height: 1.2;
  font-weight: 700;
  color: #16252d;
}

.manage-hero p {
  margin: 0.5rem 0 0;
  color: var(--muted);
  font-size: 0.8125rem;
  line-height: 1.6;
}

.manage-actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.manage-control-card {
  background: #fff;
  border-radius: 0.5rem;
  padding: 0.875rem 1rem;
  border: 0.0625rem solid #e5ebf0;
  box-shadow: none;
}

.manage-control-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.manage-control-primary,
.manage-control-actions {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  flex-wrap: wrap;
}

.manage-control-actions {
  margin-left: auto;
}

.manage-search {
  width: min(22.5rem, 100%);
}

.manage-compact-select {
  width: 10.5rem;
}

.manage-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(12.5rem, 1fr));
  gap: 0.625rem;
}

.manage-stat {
  background: #fff;
  border-radius: 0.5rem;
  border: 0.0625rem solid #e5ebf0;
  padding: 0.875rem 1rem;
  box-shadow: none;
  position: relative;
  min-height: 5.125rem;
}

.manage-stat-label {
  font-size: 0.8125rem;
  color: var(--muted);
}

.manage-stat-value {
  margin-top: 0.5rem;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text);
}

.manage-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 0.75rem;
}

.manage-toolbar-group {
  display: flex;
  gap: 0.625rem;
  align-items: center;
  flex-wrap: wrap;
}

.manage-filter-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(11.875rem, 1fr));
  gap: 0.75rem;
}

.manage-pagination {
  display: flex;
  justify-content: flex-end;
  margin-top: 0.875rem;
  padding-top: 0.75rem;
  border-top: 0.0625rem solid rgba(64, 141, 134, 0.08);
}

.manage-table-card {
  background: #fff;
  border-radius: 0.5rem;
  border: 0.0625rem solid #e5ebf0;
  box-shadow: none;
  overflow: hidden;
}

.manage-table-card .manage-toolbar {
  padding: 1rem 1.125rem 0;
}

.manage-table-card .el-table {
  --el-table-border-color: #edf1f5;
  --el-table-header-bg-color: #f6f8fb;
  --el-table-row-hover-bg-color: #f8fbfb;
}

.manage-table-card .el-table th.el-table__cell {
  color: #667985;
  font-weight: 600;
}

.manage-table-card .el-table td.el-table__cell,
.manage-table-card .el-table th.el-table__cell {
  padding-top: 0.75rem;
  padding-bottom: 0.75rem;
}

.manage-table-card .manage-pagination {
  margin: 0 1.125rem 0;
  padding: 0.875rem 0 1rem;
}

.manage-subtle-text {
  color: var(--muted);
  font-size: 0.8125rem;
}

.manage-primary-cell {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  min-width: 0;
}

.manage-primary-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: #172b35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.manage-primary-subtitle {
  font-size: 0.75rem;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.manage-amount {
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.manage-amount.is-income,
.manage-positive {
  color: #168a5a;
}

.manage-amount.is-expense,
.manage-negative {
  color: #d14343;
}

.manage-muted-dash {
  color: #a2b1ba;
}

.manage-color-cell {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: #5f7580;
  font-size: 0.8125rem;
}

.manage-color-dot {
  width: 0.75rem;
  height: 0.75rem;
  border-radius: 50%;
  display: inline-block;
  border: 0.0625rem solid rgba(0, 0, 0, 0.08);
}

.manage-progress-cell {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 0.5rem;
  align-items: center;
  min-width: 7.5rem;
}

.manage-action-links {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
}

.manage-section-eyebrow {
  font-size: 0.75rem;
  font-weight: 600;
  color: #728f9e;
  letter-spacing: 0;
  margin-bottom: 0.5rem;
}

.manage-workbench {
  background: #fff;
  border: 0.0625rem solid #e5ebf0;
  border-radius: 0.5rem;
  overflow: hidden;
}

.manage-workbench .manage-stats {
  padding: 1rem;
  background: #fbfcfd;
  border-bottom: 0.0625rem solid #e9eef3;
}

.manage-workbench .manage-stat {
  border-color: #e9eef3;
  background: #fff;
}

.manage-workbench .manage-control-card {
  border: 0;
  border-radius: 0;
  border-bottom: 0.0625rem solid #e9eef3;
}

.manage-workbench .manage-table-card {
  border: 0;
  border-radius: 0;
}

.manage-primary-button {
  min-width: 5.75rem;
}

.manage-danger-button {
  min-width: 5.125rem;
}

.ledger-shell {
  min-height: calc(100vh - 6rem);
  display: grid;
  grid-template-columns: 19.375rem minmax(28.75rem, 1fr) 22.5rem;
  gap: 0.875rem;
}

.ledger-panel {
  background: #fff;
  border-radius: 1rem;
  border: 0.0625rem solid #e8edf1;
  box-shadow: 0 0.625rem 1.75rem rgba(29, 50, 61, 0.05);
  min-width: 0;
  overflow: hidden;
}

.ledger-filter-panel,
.ledger-detail-panel {
  padding: 1.125rem;
}

.ledger-detail-column {
  display: grid;
  gap: 0.75rem;
  min-width: 0;
}

.ledger-detail-panel,
.ledger-quick-panel {
  padding: 1.125rem;
}

.ledger-panel-title,
.ledger-list-head,
.ledger-quick-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}

.ledger-panel-title h2,
.ledger-list-head h3 {
  margin: 0.25rem 0 0;
  color: #17252e;
  font-size: 1.5rem;
}

.ledger-eyebrow,
.ledger-filter-label {
  display: inline-flex;
  align-items: center;
  color: #169980;
  background: #e6f7f1;
  border-radius: 0.5rem;
  padding: 0.25rem 0.5rem;
  font-size: 0.75rem;
  font-weight: 700;
}

.ledger-search {
  margin-top: 1.125rem;
}

.ledger-search .el-input__wrapper,
.ledger-filter-block .el-select__wrapper,
.ledger-filter-block .el-date-editor.el-input__wrapper {
  min-height: 2.25rem;
  border-radius: 0.5rem;
  background: #f7f9fb;
  box-shadow: 0 0 0 0.0625rem #e5ebef inset;
}

.ledger-filter-block {
  display: grid;
  gap: 0.625rem;
  padding-top: 1.125rem;
  margin-top: 1.125rem;
  border-top: 0.0625rem solid #edf1f4;
}

.ledger-filter-actions {
  position: sticky;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  padding-top: 1.125rem;
  margin-top: 1.125rem;
  background: #fff;
}

.ledger-filter-actions .el-button {
  height: 2.25rem;
  border-radius: 0.5rem;
  font-weight: 700;
}

.ledger-list-panel {
  display: flex;
  flex-direction: column;
}

.ledger-month-card {
  margin: 1rem;
  padding: 1.125rem;
  border-radius: 0.875rem;
  background: linear-gradient(180deg, #fbfcfd 0%, #f8fbfa 100%);
  border: 0.0625rem solid #e7ecef;
}

.ledger-summary-head {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  min-width: 0;
}

.ledger-filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  min-width: 0;
}

.ledger-filter-tags .el-tag {
  max-width: 11.25rem;
  border-color: #bfe7df;
  background: #f1fbf8;
  color: #188d78;
  font-weight: 700;
}

.ledger-filter-tags .el-tag__content {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ledger-month-picker {
  width: 8.25rem;
  flex: 0 0 8.25rem;
}

.ledger-month-picker.el-date-editor.el-input,
.ledger-month-picker.el-date-editor.el-input__wrapper {
  width: 8.25rem;
}

.ledger-month-picker .el-input__wrapper {
  min-height: 2.375rem;
  border-radius: 62.4375rem;
  background: #fff;
  box-shadow: 0 0 0 0.0625rem #d8e1e8 inset;
  padding: 0 0.875rem;
  cursor: pointer;
}

.ledger-month-picker .el-input__inner {
  color: #10242f;
  font-size: 0.9375rem;
  font-weight: 800;
  cursor: pointer;
}

.ledger-month-picker .el-input__prefix,
.ledger-month-picker .el-input__suffix {
  color: #10242f;
}

.ledger-no-clear .el-input__clear,
.ledger-no-clear .el-select__caret.is-show-close,
.ledger-month-picker .el-input__clear,
.ledger-month-picker .el-select__caret.is-show-close {
  display: none !important;
}

.ledger-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.125rem;
  margin-top: 1.125rem;
}

.ledger-summary-item {
  border-left: 0.1875rem solid #d7dee4;
  padding-left: 0.625rem;
  min-width: 0;
}

.ledger-summary-item span,
.ledger-list-head span,
.ledger-bill-meta,
.ledger-detail-time,
.ledger-detail-rows span {
  color: #8c99a8;
  font-size: 0.75rem;
}

.ledger-summary-item strong {
  display: block;
  margin-top: 0.3125rem;
  font-size: 1.5rem;
  font-variant-numeric: tabular-nums;
}

.ledger-summary-item.expense {
  border-color: #ff5252;
}

.ledger-summary-item.income {
  border-color: #1f7af0;
}

.ledger-summary-item.balance {
  border-color: #30b59c;
}

.ledger-summary-item.expense strong,
.ledger-bill-amount.expense {
  color: #ff474d;
}

.ledger-summary-item.income strong,
.ledger-bill-amount.income {
  color: #24a17d;
}

.ledger-list-head {
  padding: 0.125rem 1rem 0.875rem;
  border-bottom: 0.0625rem solid #edf1f4;
  min-width: 0;
}

.ledger-list-head > div:first-child {
  min-width: 7rem;
  flex: 1 1 8.75rem;
}

.ledger-list-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex: 0 1 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.ledger-list-actions .el-button {
  height: 2.125rem;
  border-radius: 0.625rem;
  font-weight: 700;
  color: #17313f;
  border-color: #b8c9d4;
  background: #fff;
}

.ledger-list-actions .el-button > span {
  color: inherit;
}

.ledger-list-actions .el-button--primary,
.ledger-add-button.el-button--primary {
  color: #ffffff !important;
  background: #1fa891;
  border-color: #1fa891;
  box-shadow: 0 0.5rem 1.125rem rgba(31, 168, 145, 0.18);
}

.ledger-list-actions .el-button--primary > span,
.ledger-add-button.el-button--primary > span {
  color: #ffffff !important;
}

.ledger-list-actions .el-button--primary:hover,
.ledger-add-button.el-button--primary:hover {
  color: #fff !important;
  background: #178f7d;
  border-color: #178f7d;
}

.ledger-list-actions .el-button:not(.el-button--primary):not(.el-button--danger):hover {
  color: #0b7f70;
  border-color: #7cc8c1;
  background: #f1fbf8;
}

.ledger-list-actions .el-button--danger.is-plain {
  color: #d9363e;
  border-color: #f3b7bb;
  background: #fff1f2;
}

.ledger-list-actions .el-button--danger.is-plain:hover {
  color: #fff;
  border-color: #e84f57;
  background: #e84f57;
}

.ledger-list-actions .el-button.is-disabled,
.ledger-list-actions .el-button.is-disabled:hover {
  color: #8797a3;
  border-color: #d8e2e9;
  background: #f5f8fa;
  opacity: 1;
}

.ledger-list-actions .el-button.is-disabled > span,
.ledger-list-actions .el-button.is-disabled .el-icon {
  color: #8797a3;
}

.ledger-list-actions .el-button .el-icon {
  color: inherit;
}

.ledger-stream {
  flex: 1;
  min-height: 0;
  overflow: auto;
  padding: 0.625rem 0.625rem 0;
}

.ledger-bill-item {
  display: grid;
  grid-template-columns: auto 2.75rem minmax(0, 1fr) auto;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.25rem;
  padding: 0.8125rem 0.625rem;
  border: 0.0625rem solid transparent;
  border-radius: 0.75rem;
  cursor: pointer;
  transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
}

.ledger-bill-item:hover,
.ledger-bill-item.active {
  background: #eef8f5;
  border-color: #d7eee8;
}

.ledger-bill-item:hover {
  transform: translateY(-0.0625rem);
}

.ledger-bill-icon,
.ledger-detail-icon {
  width: 2.75rem;
  height: 2.75rem;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: #f1f3f5;
  color: #17252e;
  font-size: 1.25rem;
}

.ledger-bill-icon.income {
  background: #e8f3ff;
  color: #1f7af0;
}

.ledger-bill-icon.expense {
  background: #fff0f1;
  color: #ff474d;
}

.ledger-bill-title {
  font-weight: 700;
  color: #17252e;
  display: flex;
