}

.stats-chart-row {
  grid-template-columns: 13.25rem minmax(0, 1fr);
  gap: 1rem;
  align-items: center;
  flex: 1;
  min-height: 0;
  min-width: 0;
  overflow: visible;
}

.stats-chart-row > div:first-child {
  width: 13.25rem;
  overflow: visible;
  position: relative;
  z-index: 2;
}

.stats-pie-wrap,
.stats-pie-wrap > div,
.stats-pie-wrap canvas {
  overflow: visible !important;
}

.stats-rank-list {
  gap: 0.4375rem;
  min-width: 0;
  max-height: 14rem;
  overflow: auto;
  padding-right: 0.125rem;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.stats-rank-list::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

.stats-rank-item {
  grid-template-columns: 0.75rem minmax(4.75rem, 1fr) 4.625rem 3.375rem;
  gap: 0.5rem;
  align-items: center;
  min-height: 1.875rem;
  padding: 0.1875rem 0.25rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
}

.stats-rank-item:hover {
  background: #f6faf9;
}

.stats-rank-item span {
  width: 0.75rem;
  height: 0.75rem;
  border-radius: 50%;
}

.stats-rank-item strong {
  font-weight: 500;
  color: #233849;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.25;
  min-width: 0;
}

.stats-rank-item em {
  text-align: right;
  font-size: 0.8125rem;
  color: #ff474d;
  white-space: nowrap;
}

.stats-rank-item small {
  text-align: right;
  font-size: 0.8125rem;
  color: #8f9cab;
  min-width: 3.125rem;
  white-space: nowrap;
}

.stats-card-options {
  margin-top: 0.5rem;
  min-height: 1.375rem;
  align-items: center;
}

.stats-card-options .el-checkbox {
  height: 1.375rem;
  margin-right: 0;
}

.stats-card-options .el-checkbox__label {
  font-size: 0.75rem;
  color: #6f7f8d;
  padding-left: 0.3125rem;
}

.stats-fixed-card {
  height: 19.75rem;
  min-height: 19.75rem;
  max-height: 19.75rem;
  padding: 1.125rem 1.25rem;
  border: 0;
  box-shadow: none;
}

.stats-fixed-card .stats-detail-list {
  flex: 1;
  max-height: none;
  min-height: 0;
  margin-top: 0.875rem;
  gap: 0;
  overflow: auto;
  padding-right: 0;
}

.stats-detail-list button {
  display: grid;
  grid-template-columns: 0.3125rem 2.5rem minmax(0, 1fr) 6.75rem;
  min-height: 4rem;
  gap: 0.75rem;
  padding: 0.625rem 0;
  align-items: center;
  border-bottom: 0.0625rem solid #edf1f4;
  position: relative;
}

.stats-detail-list .stats-detail-color {
  width: 0.3125rem;
  min-width: 0.3125rem;
  height: 2.375rem;
  border-radius: 62.4375rem;
}

.stats-detail-list .stats-detail-icon-bubble {
  width: 2.5rem;
  min-width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  background: #f1f3f5;
  color: #60717e;
  display: grid;
  place-items: center;
}

.stats-detail-list button.is-expense .stats-detail-icon-bubble {
  background: #fff4f1;
  color: #ff7d3b;
}

.stats-detail-list button.is-income .stats-detail-icon-bubble {
  background: #edf8f5;
  color: #24a17d;
}

.stats-detail-list .stats-detail-icon-bubble .el-icon {
  font-size: 1.1875rem;
}

.stats-detail-list .stats-detail-copy {
  display: grid;
  gap: 0.375rem;
  min-width: 0;
  width: auto;
  height: auto;
  border-radius: 0;
}

.stats-detail-list button strong {
  font-size: 0.875rem;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #17252e;
}

.stats-detail-list button small {
  color: #8f9cab;
  font-size: 0.8125rem;
  line-height: 1;
}

.stats-detail-list button em {
  grid-column: 4;
  justify-self: end;
  align-self: center;
  font-size: 0.875rem;
  font-weight: 700;
  text-align: right;
  white-space: nowrap;
}

.stats-detail-list button em.expense {
  color: #ff474d;
}

.stats-detail-list button em.income {
  color: #24a17d;
}

.category-icon-preview {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
}

.category-icon-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.625rem;
  width: 100%;
}

.category-icon-grid button {
  min-height: 4.125rem;
  border: 0.0625rem solid #edf1f4;
  border-radius: 0.75rem;
  background: #f7f9fb;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 0.375rem;
  cursor: pointer;
  color: #17252e;
}

.category-icon-grid button:hover,
.category-icon-grid button.active {
  border-color: #28b79f;
  background: #e9f8f4;
  color: #169980;
}

.category-icon-grid .el-icon {
  font-size: 1.375rem;
}

.category-icon-grid span {
  font-size: 0.75rem;
}

.notes-shell {
  min-height: calc(100vh - 6rem);
  display: grid;
  grid-template-columns: minmax(0, 1.45fr) minmax(21.25rem, 0.8fr);
  gap: 0.875rem;
}

.notes-editor-card,
.notes-list-card {
  background: #fff;
  border: 0.0625rem solid #e5ebf0;
  border-radius: 0.625rem;
  padding: 1rem;
  min-width: 0;
}

.notes-card-head,
.notes-list-head,
.notes-item-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}

.notes-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.625rem;
  margin: 0.875rem 0 1rem;
}

.notes-summary-grid > div {
  display: grid;
  gap: 0.375rem;
  padding: 0.75rem;
  border: 0.0625rem solid #edf1f4;
  border-radius: 0.5rem;
  background: #fbfcfd;
}

.notes-summary-grid span {
  color: var(--muted);
  font-size: 0.75rem;
}

.notes-summary-grid strong {
  color: #10242f;
  font-size: 1.25rem;
}

.notes-card-head {
  margin-bottom: 0.875rem;
}

.notes-card-head h2,
.notes-list-head h3,
.notes-item h4 {
  margin: 0;
  color: #17252e;
}

.notes-card-head h2 {
  margin-top: 0.25rem;
  font-size: 1.375rem;
}

.notes-eyebrow {
  display: inline-flex;
  align-items: center;
  color: #169980;
  background: #e6f7f1;
  border-radius: 0.5rem;
  padding: 0.25rem 0.5rem;
  font-size: 0.75rem;
  font-weight: 700;
}

.notes-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.notes-editor-wrap {
  width: 100%;
  border: 0.0625rem solid #e5ebf0;
  border-radius: 0.5rem;
  overflow: hidden;
}

.notes-editor {
  min-height: 22.5rem;
  background: #fff;
}

.notes-editor-wrap .ql-toolbar {
  border: 0;
  border-bottom: 0.0625rem solid #e5ebf0;
  background: #f7f9fb;
}

.notes-editor-wrap .ql-container {
  border: 0;
  min-height: 19.5rem;
  font-size: 0.875rem;
}

.notes-side {
  display: grid;
  gap: 0.875rem;
  min-width: 0;
}

.notes-list-card {
  min-height: 0;
  max-height: calc((100vh - 7rem) / 2);
  display: flex;
  flex-direction: column;
}

.notes-list-head {
  margin-bottom: 0.625rem;
}

.notes-list-head span,
.notes-item small {
  color: var(--muted);
  font-size: 0.75rem;
}

.notes-scroll-list {
  display: grid;
  gap: 0.625rem;
  overflow: auto;
  min-height: 0;
  padding-right: 0.125rem;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.notes-scroll-list::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

.notes-item {
  padding: 0.75rem;
  border: 0.0625rem solid #edf1f4;
  border-radius: 0.5rem;
  background: #fbfcfd;
}

.notes-item.clickable {
  cursor: pointer;
}

.notes-item.clickable:hover {
  border-color: #cfece5;
  background: #f6fbfa;
}

.notes-rich-text {
  margin-top: 0.5rem;
  color: #667985;
  font-size: 0.8125rem;
  line-height: 1.65;
  word-break: break-word;
}

.notes-rich-text :first-child {
  margin-top: 0;
}

.notes-rich-text :last-child {
  margin-bottom: 0;
}

.notes-rich-text a {
  color: #169980;
}

@media (max-width: 73.75rem) {
  .notes-shell {
    grid-template-columns: 1fr;
  }

  .notes-side {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 47.5rem) {
  .manage-hero,
  .manage-control-row,
  .page-title,
  .notes-card-head {
    align-items: stretch;
    flex-direction: column;
  }

  .manage-actions,
  .manage-control-primary,
  .manage-control-actions,
  .notes-actions {
    width: 100%;
  }

  .manage-search,
  .manage-compact-select,
  .manage-actions .el-button,
  .manage-control-actions .el-button,
  .notes-actions .el-button {
    width: 100%;
  }

  .notes-side {
    grid-template-columns: 1fr;
  }

  .notes-list-card {
    max-height: 22.5rem;
  }

  .ledger-list-head,
  .ledger-list-actions {
    align-items: flex-start;
    flex-direction: row;
  }

  .ledger-list-actions .el-button {
    width: auto;
    flex: 0 0 auto;
    margin-left: 0;
  }

  .ledger-bill-item {
    grid-template-columns: auto 2.5rem minmax(0, 1fr);
  }

  .ledger-bill-amount {
    grid-column: 3;
    justify-self: start;
    padding-left: 0;
  }

  .stats-chart-row {
    grid-template-columns: 1fr;
  }

  .stats-chart-row > div:first-child {
    width: 100%;
  }

  .stats-card,
  .stats-fixed-card {
    height: auto;
    min-height: 18.75rem;
  }

  .stats-rank-item {
    grid-template-columns: 0.75rem minmax(0, 1fr) 5.125rem 3.375rem;
  }

  .exception-card {
    padding: 1.5rem;
    border-radius: 1.375rem;
  }

  .exception-actions .el-button {
    width: 100%;
  }
}

/* Visual refresh layer: keeps every user page on the same polished surface system. */
:root {
  --surface: #ffffff;
  --surface-soft: #f7fbfa;
  --surface-tint: #eef8f6;
  --line-soft: rgba(64, 141, 134, 0.12);
  --shadow-card: 0 0.75rem 1.75rem rgba(29, 50, 61, 0.055);
  --shadow-hover: 0 1rem 2.25rem rgba(29, 50, 61, 0.075);
}

body {
  background:
    radial-gradient(circle at 8% 6%, rgba(128, 203, 196, 0.2), transparent 18rem),
    radial-gradient(circle at 92% 8%, rgba(79, 142, 247, 0.1), transparent 16rem),
    var(--layout-bg);
}

.main-layout-main {
  padding: 1rem 1.125rem 1.25rem;
}

.main-layout-header,
.main-layout-aside {
  box-shadow: 0 0.625rem 1.5rem rgba(29, 50, 61, 0.035);
}

.main-layout-nav-item,
.main-layout-icon-button,
.main-layout-user,
.el-button {
  transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
}

.el-button {
  border-radius: 0.625rem;
  font-weight: 800;
}

.el-button:not(.is-disabled):hover {
  transform: translateY(-0.0625rem);
}

.el-button--primary {
  border-color: #24a795;
  background: linear-gradient(135deg, #26a69a 0%, #408d86 100%);
  box-shadow: 0 0.5rem 1.125rem rgba(38, 166, 154, 0.18);
}

.el-button--primary:hover {
  border-color: #1f9183;
  background: linear-gradient(135deg, #23998e 0%, #377f79 100%);
}

.el-input__wrapper,
.el-select__wrapper,
.el-date-editor.el-input__wrapper,
.el-textarea__inner,
.el-input-number .el-input__wrapper {
  border-radius: 0.625rem;
  background: #fbfdfd;
  box-shadow: 0 0 0 0.0625rem #dfeceb inset;
}

.el-input__wrapper.is-focus,
.el-select__wrapper.is-focused,
.el-date-editor.el-input__wrapper.is-focus,
.el-textarea__inner:focus {
  box-shadow: 0 0 0 0.0625rem #26a69a inset, 0 0 0 0.1875rem rgba(38, 166, 154, 0.1);
}

.el-dialog {
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 1.5rem 4rem rgba(29, 50, 61, 0.18);
}

.el-dialog__header {
  padding: 1rem 1.125rem 0.625rem;
  margin: 0;
  background: linear-gradient(180deg, #fbfefd 0%, #ffffff 100%);
  border-bottom: 0.0625rem solid #edf3f2;
}

.el-dialog__title {
  color: #132933;
  font-weight: 900;
}

.el-dialog__body {
  padding: 1rem 1.125rem;
}

.el-dialog__footer {
  padding: 0.875rem 1.125rem 1rem;
  border-top: 0.0625rem solid #edf3f2;
  background: #fbfdfd;
}

.el-table {
  --el-table-border-color: #edf3f2;
  --el-table-header-bg-color: #f5faf9;
  --el-table-row-hover-bg-color: #f3fbf9;
  color: #263943;
}

.el-table th.el-table__cell {
  color: #5f7580;
  font-weight: 800;
}

.el-table .cell {
  line-height: 1.45;
}

.el-tag {
  border-radius: 62.4375rem;
  font-weight: 800;
}

.page-card,
.ledger-panel,
.stats-card,
.stats-fixed-card,
.notes-editor-card,
.notes-list-card,
.book-card,
.manage-control-card,
.manage-table-card,
.account-page-head,
.account-control-card,
.account-type-panel,
.account-table-panel,
.account-stat-card,
.category-page-head,
.category-control-card,
.category-tree-panel,
.category-table-panel,
.category-stat-card {
  border-color: var(--line-soft);
  border-radius: 0.75rem;
  box-shadow: var(--shadow-card);
}

.page-card:hover,
.book-card:hover,
.notes-item:hover,
.stats-rank-item:hover,
.stats-drawer-item:hover {
  box-shadow: var(--shadow-hover);
}

.manage-hero,
.page-title,
.notes-card-head,
.ledger-panel-title {
  color: #132933;
}

.manage-hero,
.page-card,
.book-card,
.notes-editor-card,
.notes-list-card,
.stats-card,
.stats-fixed-card {
  background: linear-gradient(180deg, #ffffff 0%, #fbfefd 100%);
}

.book-card {
  transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
}

.book-card:hover {
  border-color: #a7ddd6;
  transform: translateY(-0.0625rem);
}

.book-card.active {
  background: linear-gradient(135deg, #f5fcfa 0%, #eef8ff 100%);
  box-shadow: 0 0 0 0.1875rem rgba(38, 166, 154, 0.08), var(--shadow-card);
}

.ledger-panel {
  border-radius: 1rem;
}

.ledger-month-card,
.stats-total-card,
.stats-book-card,
.notes-summary-grid > div,
.notes-item,
.budget-dialog-card,
.budget-total-option,
.budget-category-block {
  border-color: #e4eeec;
  background: linear-gradient(180deg, #ffffff 0%, #f8fcfb 100%);
}

.ledger-bill-item,
.stats-drawer-item,
.notes-item {
  transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
}

.ledger-bill-item:hover,
.ledger-bill-item.active {
  background: #f1faf8;
  border-color: #ccebe5;
}

.stats-card,
.stats-fixed-card {
  border: 0.0625rem solid var(--line-soft);
}

.stats-rank-list,
.stats-report-list,
.ledger-stream,
.notes-scroll-list {
  scrollbar-width: thin;
  scrollbar-color: rgba(38, 166, 154, 0.28) transparent;
}

.stats-rank-list::-webkit-scrollbar,
.stats-report-list::-webkit-scrollbar,
.ledger-stream::-webkit-scrollbar,
.notes-scroll-list::-webkit-scrollbar {
  width: 0.375rem;
  height: 0.375rem;
  display: block;
}

.stats-rank-list::-webkit-scrollbar-thumb,
.stats-report-list::-webkit-scrollbar-thumb,
.ledger-stream::-webkit-scrollbar-thumb,
.notes-scroll-list::-webkit-scrollbar-thumb {
  border-radius: 62.4375rem;
  background: rgba(38, 166, 154, 0.28);
}

.stats-card h3,
.stats-card-head h3,
.notes-card-head h2,
.notes-list-head h3,
.ledger-list-head h3,
.ledger-panel-title h2 {
  color: #132933;
  font-weight: 900;
}

.import-confirm-warning,
.budget-warning-item {
  border: 0.0625rem solid #ffe1b8;
}

@media (max-width: 47.5rem) {
  .main-layout-main {
    padding: 0.75rem;
  }

  .el-dialog {
    width: calc(100vw - 1rem) !important;
  }
}
